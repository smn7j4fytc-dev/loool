# ────────────────────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/loyalty_saas"

# ────────────────────────────────────────────────────────────────────────────
# APP
# ────────────────────────────────────────────────────────────────────────────
API_PORT=3001
WEB_URL="http://localhost:3000"
API_URL="http://localhost:3001"
NODE_ENV="development"

# ────────────────────────────────────────────────────────────────────────────
# AUTH
# ────────────────────────────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-un-string-aleatorio-seguro-en-produccion"
JWT_EXPIRES_IN="7d"

# ────────────────────────────────────────────────────────────────────────────
# SUPER ADMIN (usado en seed)
# ────────────────────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL="admin@loyaltysaas.com"
SUPER_ADMIN_PASSWORD="superadmin123"

# ────────────────────────────────────────────────────────────────────────────
# 🔑 CREDENCIALES REALES — GOOGLE WALLET
# Guía completa en README.md → "Obtener credenciales de Google Wallet"
#
# Mientras GOOGLE_WALLET_MOCK=true el sistema devuelve URLs de prueba locales
# y loguea los payloads que se enviarían. Cambia a false cuando tengas creds.
# ────────────────────────────────────────────────────────────────────────────
GOOGLE_WALLET_MOCK=true

# Del Google Pay & Wallet Console (pay.google.com/business/console)
GOOGLE_WALLET_ISSUER_ID=""

# Del archivo JSON de la service account de Google Cloud
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=""

# La private_key del JSON (con los \n literales, copiada tal cual del JSON)
GOOGLE_WALLET_SERVICE_ACCOUNT_PRIVATE_KEY=""

# ────────────────────────────────────────────────────────────────────────────
# 🔑 CREDENCIALES REALES — APPLE WALLET
# Guía completa en README.md → "Obtener credenciales de Apple Wallet"
# Requiere Apple Developer Program ($99/año)
#
# Mientras APPLE_WALLET_MOCK=true retorna un .pkpass demo firmado con certs
# auto-generados (solo para inspección, no se puede agregar al Wallet real).
# ────────────────────────────────────────────────────────────────────────────
APPLE_WALLET_MOCK=true

# Tu Pass Type ID (ej: pass.com.tuempresa.loyalty)
APPLE_PASS_TYPE_ID="pass.com.tuempresa.loyalty"

# Tu Team ID (10 caracteres, visible en developer.apple.com)
APPLE_TEAM_ID=""

# Certificados en base64 (ver README para cómo generarlos)
APPLE_WWDR_CERT_BASE64=""
APPLE_PASS_CERT_BASE64=""
APPLE_PASS_KEY_BASE64=""
APPLE_PASS_KEY_PASSPHRASE=""

# APNs Auth Key (.p8 file) para push updates
APPLE_APN_KEY_BASE64=""
APPLE_APN_KEY_ID=""

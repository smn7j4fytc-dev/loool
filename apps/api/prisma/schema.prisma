generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum CardType {
  PUNCH     // Sellos: llena X sellos → gana recompensa
  POINTS    // Puntos: acumula puntos con cada compra
  CASHBACK  // Cashback: porcentaje del monto gastado
  DISCOUNT  // Descuento: tarjeta de descuento permanente
  COUPON    // Cupón: descuento único por visita
  PREPAID   // Prepago: saldo recargable
}

enum Plan {
  FREE        // Hasta 100 clientes, 1 negocio
  STARTER     // Hasta 500 clientes
  PRO         // Ilimitado + analytics avanzado
  ENTERPRISE  // Multi-ubicación + API access
}

enum NotificationType {
  PROMO
  REMINDER
  REWARD
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPER ADMIN — dueño de la plataforma
// ─────────────────────────────────────────────────────────────────────────────

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS — tenant principal
// ─────────────────────────────────────────────────────────────────────────────

model Business {
  id   String @id @default(cuid())
  slug String @unique // usado en /r/<slug> y como classId en Google Wallet

  // Identidad visual
  name           String
  logoUrl        String?
  primaryColor   String  @default("#7C3AED")
  secondaryColor String  @default("#FFFFFF")
  textColor      String  @default("#FFFFFF")

  // Configuración de la tarjeta de lealtad
  cardType  CardType @default(PUNCH)
  threshold Int      @default(10)    // sellos/puntos necesarios para la recompensa
  reward    String   @default("1 gratis") // descripción de la recompensa
  pointsLabel String @default("Sellos")   // label que ve el cliente en la tarjeta

  // Ubicaciones para notificación por cercanía (nativa Apple/Google Wallet)
  // Formato: [{lat: number, lng: number, name: string, maxDistance?: number}]
  locations Json?

  // Plan y estado
  plan   Plan    @default(FREE)
  active Boolean @default(true)

  // Autenticación del admin del negocio
  adminEmail    String @unique
  adminPassword String

  // ── Google Wallet ──────────────────────────────────────────────
  // Se crea una vez al configurar el negocio.
  // Formato: "<issuerId>.<businessId>"
  googleClassId String?

  // ── Apple Wallet ───────────────────────────────────────────────
  // Si usas un Pass Type ID compartido entre negocios, déjalo en null
  // y usa el global de .env. Si cada negocio tiene el suyo, ponlo aquí.
  applePassTypeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers     Customer[]
  visits        Visit[]
  notifications Notification[]
  staff         Staff[]
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMER — cliente registrado en un negocio
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name  String
  email String
  phone String?

  // Progreso de lealtad
  balance      Float @default(0) // sellos, puntos, cashback o saldo según cardType
  totalVisits  Int   @default(0)
  totalRewards Int   @default(0) // veces que canjeó la recompensa

  // Código único del cliente (se muestra como QR en la tarjeta)
  // El staff escanea este código para registrar visitas
  cardCode String @unique @default(cuid())

  // ── Google Wallet ──────────────────────────────────────────────
  // Formato: "<issuerId>.<customerId>"
  googleObjectId String? @unique

  // ── Apple Wallet ───────────────────────────────────────────────
  applePassSerial String?    @unique
  appleAuthToken  String?    // token para autenticar el web service de PassKit
  appleDevices    AppleDevice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits Visit[]

  @@unique([businessId, email])
}

// ─────────────────────────────────────────────────────────────────────────────
// APPLE DEVICE — dispositivos registrados para push de Apple Wallet
// ─────────────────────────────────────────────────────────────────────────────

model AppleDevice {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  deviceLibraryIdentifier String
  pushToken               String
  passTypeIdentifier      String

  createdAt DateTime @default(now())

  @@unique([deviceLibraryIdentifier, passTypeIdentifier])
}

// ─────────────────────────────────────────────────────────────────────────────
// STAFF — empleados del negocio
// ─────────────────────────────────────────────────────────────────────────────

model Staff {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name     String
  email    String  @unique
  password String
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits Visit[]
}

// ─────────────────────────────────────────────────────────────────────────────
// VISIT — cada sello/visita/transacción registrada por el staff
// ─────────────────────────────────────────────────────────────────────────────

model Visit {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staffId    String?
  staff      Staff?   @relation(fields: [staffId], references: [id])

  pointsEarned Float   @default(1)     // sellos/puntos ganados en esta visita
  amount       Float?                  // monto gastado (para cashback/prepago)
  rewardGiven  Boolean @default(false) // true si en esta visita se entregó recompensa
  note         String?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION — campañas push enviadas por el admin
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title          String
  body           String
  type           NotificationType @default(PROMO)

  sentAt         DateTime?
  recipientCount Int      @default(0)

  createdAt DateTime @default(now())
}
